generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  active
  waiting
  deferred
  done
  dropped
}

enum TaskPriority {
  low
  medium
  high
  critical
}

enum SourceType {
  manual
  email
  calendar
  message
  llm
  fedos
}

enum ActorType {
  user
  llm
  system
}

enum ProjectStatus {
  active
  paused
  done
  archived
}

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String?
  status        TaskStatus   @default(active)
  priority      TaskPriority @default(medium)
  category_id   String
  project_id    String?
  owner         String       @default("Federico")
  due_at        DateTime?
  source_type   SourceType   @default(manual)
  source_ref    String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  completed_at  DateTime?

  category Category     @relation(fields: [category_id], references: [id])
  project  Project?     @relation(fields: [project_id], references: [id])
  tags     TaskTag[]
  events   TaskEvent[]
  sources  TaskSource[]

  @@index([status])
  @@index([priority])
  @@index([due_at])
  @@index([created_at])
  @@index([category_id])
  @@index([project_id])
}

model Category {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  color      String    @default("#6b7280")
  icon       String    @default("tag")
  sort_order Int       @default(0)
  archived_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  tasks Task[]

  @@index([sort_order])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  color       String
  description String?
  status      ProjectStatus @default(active)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  tasks Task[]
}

model PriorityConfig {
  priority  TaskPriority @id
  color     String
}

model StatusConfig {
  status    TaskStatus @id
  color     String
}

model Tag {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  tasks TaskTag[]
}

model TaskTag {
  task_id String
  tag_id  String

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([task_id, tag_id])
  @@index([tag_id])
}

model TaskEvent {
  id         String    @id @default(cuid())
  task_id    String
  event_type String
  old_value  Json?
  new_value  Json?
  reason     String?
  actor      ActorType @default(user)
  created_at DateTime  @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id, created_at])
}

model TaskSource {
  id          String     @id @default(cuid())
  task_id      String
  source_type SourceType
  source_ref  String?
  summary     String?
  captured_at DateTime   @default(now())

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([source_type])
}
