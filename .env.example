# Core app
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fedos_tasks?schema=public"

# Generate with:
# node -e "const b=require('bcryptjs');console.log(b.hashSync('your-password',10))"
# IMPORTANT: escape $ signs with \$ in .env files because Next.js expands $.
AUTH_PASSWORD_HASH="\$2b\$10\$..."
AUTH_SECRET="replace-with-long-random-secret"

# LLM provider for real briefing generation
ANTHROPIC_API_KEY=""

# FedOS Memory read-only context
FEDOS_MEMORY_ROOT="/Users/federico_valori/Documents/FedOS-Memory"
FEDOS_DIGEST_ROOT="/Users/federico_valori/Documents/FedOS-Intelligence/data/memory_digest"

# Microsoft 365 / Outlook ingestion
# Copy the values from the legacy m365_poc/.env into the M365_* names below.
# Legacy CLIENT_ID            -> M365_CLIENT_ID
# Legacy CLIENT_SECRET        -> M365_CLIENT_SECRET
# Legacy TOKEN_ENCRYPTION_KEY -> M365_TOKEN_ENCRYPTION_KEY
M365_CLIENT_ID=""
M365_CLIENT_SECRET=""
M365_TENANT_ID="common"
M365_SCOPES="openid profile offline_access User.Read Mail.Read Calendars.Read"
M365_TOKEN_PATH="/Users/federico_valori/Documents/FedOS-Intelligence/m365_poc/.secrets/token.enc"
M365_TOKEN_ENCRYPTION_KEY=""
